{
  "$schema": "https://raw.githubusercontent.com/nicehash/tauri-schema/v2/schema.json",
  "productName": "Savant",
  "version": "0.1.0",
  "identifier": "com.savant.app",
  "build": {
    "beforeDevCommand": "node ../../../scripts/setup-updater-keys.js && npm --prefix ../../../dashboard run dev",
    "beforeBuildCommand": "node ../../../scripts/setup-updater-keys.js && set TAURI_BUILD=1 && npm --prefix ../../../dashboard run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../../dashboard/out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Savant Swarm Dashboard",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' ws://localhost:* http://localhost:* wss://localhost:*"
    },
    "trayIcon": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "2026 Savant",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/fame0528/Savant/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE2OTIzQzcwRjI4MkI1NzEKUldSeHRZTHljRHlTRmc1amJ5UFJudlNUVVIzQ2QvalRXaHpMRitkemtYL2VCWG1NelYrTElDdkcK"
    }
  }
}
